# Environment selection
# Allowed values used by src/config/environments.ts: development, production
VITE_ENVIRONMENT=development

# Development API base URL
VITE_LOCAL_API_URL=http://localhost:8000/v1

# Production API base URL
VITE_PRODUCTION_API_URL=https://recommendme-api-production.up.railway.app/v1

# Request timeout in milliseconds (used by src/services/api.ts)
VITE_API_TIMEOUT=30000

# Enable API debug logging in browser console: true | false
VITE_DEBUG_API=false
